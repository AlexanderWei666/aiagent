# LLM 配置示例
# 复制此文件为 .env，然后填入真实的值

# LLM 提供商 (openrouter, groq, ollama, etc.)
LLM_PROVIDER=openrouter

# API 密钥（从环境变量读取，不要硬编码！）
LLM_API_KEY=your_api_key_here

# 模型名称
LLM_MODEL=z-ai/glm-4.5-air:free

# API 基础 URL
LLM_BASE_URL=https://openrouter.ai/api/v1

# 温度参数 (0.0-1.0，越低越确定性)
LLM_TEMPERATURE=0.4

# 最大历史消息数
MAX_HISTORY=20

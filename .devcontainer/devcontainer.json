{
  "name": "aiagent",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "DEBIAN_MIRROR": "mirrors.tuna.tsinghua.edu.cn",
      "NPM_REGISTRY": "https://registry.npmmirror.com",
      "PYPI_INDEX_URL": "https://pypi.tuna.tsinghua.edu.cn/simple",
      "PYPI_TRUSTED_HOST": "pypi.tuna.tsinghua.edu.cn"
    }
  },

  "containerEnv": {
    "NPM_CONFIG_REGISTRY": "https://registry.npmmirror.com",
    "PIP_INDEX_URL": "https://pypi.tuna.tsinghua.edu.cn/simple",
    "PIP_TRUSTED_HOST": "pypi.tuna.tsinghua.edu.cn"
  },

  // 让容器内工作区路径与宿主机保持一致
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind,consistency=cached",
  "workspaceFolder": "${localWorkspaceFolder}",

  // Node.js 已移入 Dockerfile，features 不再需要
  // "features": { "ghcr.io/devcontainers/features/node:1": {} },

  // 预留项目初始化命令（依赖安装已前移到 Dockerfile）
  "postCreateCommand": "echo 'devcontainer is ready'",

  "mounts": [
    // Claude Code（Pro 必须，两个都要挂）
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind",

    // Git 完整配置（alias 等不会自动同步）
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind",

    // SSH Key
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly",

    // pip / npm 缓存持久化，挂到开发用户目录才能真正命中缓存
    "source=aiagent-pip-cache,target=/home/vscode/.cache/pip,type=volume",
    "source=aiagent-npm-cache,target=/home/vscode/.npm,type=volume"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "christian-kohler.path-intellisense",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "github.copilot-chat",
        "ms-azuretools.vscode-containers",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "oderwat.indent-rainbow"
      ],
      "settings": {
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.autoImportCompletions": true,
        "python.analysis.inlayHints.variableTypes": true,
        "python.analysis.inlayHints.functionReturnTypes": true,
        "editor.formatOnSave": true,
        "editor.suggestSelection": "first"
      }
    }
  }
}
{
  "name": "aiagent",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "DEBIAN_MIRROR": "mirrors.tuna.tsinghua.edu.cn",
      "PYPI_INDEX_URL": "https://pypi.tuna.tsinghua.edu.cn/simple",
      "PYPI_TRUSTED_HOST": "pypi.tuna.tsinghua.edu.cn"
    }
  },

  // 让容器内工作区路径与宿主机保持一致
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind,consistency=cached",
  "workspaceFolder": "${localWorkspaceFolder}",

  "remoteUser": "root",

  "postCreateCommand": "mkdir -p data/checkpoints && echo 'devcontainer is ready'",

  "mounts": [
    // Claude Code
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/root/.claude.json,type=bind",

    // Codex
    "source=${localEnv:HOME}/.codex,target=/root/.codex,type=bind",

    // Git
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind",

    // SSH Key
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "openai.chatgpt",
        "christian-kohler.path-intellisense",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "github.copilot-chat",
        "ms-azuretools.vscode-containers",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "oderwat.indent-rainbow"
      ],
      "settings": {
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.autoImportCompletions": true,
        "python.analysis.inlayHints.variableTypes": true,
        "python.analysis.inlayHints.functionReturnTypes": true,
        "editor.formatOnSave": true,
        "editor.suggestSelection": "first"
      }
    }
  }
}

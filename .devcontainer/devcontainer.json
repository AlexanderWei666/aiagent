{
  "name": "aiagent",
  "image": "mcr.microsoft.com/devcontainers/python:3-3.12-trixie",

  // 让容器内工作区路径与宿主机保持一致
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind,consistency=cached",
  "workspaceFolder": "${localWorkspaceFolder}",

  // Node.js feature，仅用于运行 Claude Code CLI
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },

  // 配置 pip 国内镜像，安装依赖，安装 Claude Code CLI
  "postCreateCommand": "pip config set global.index-url https://mirrors.aliyun.com/pypi/simple/ && pip config set global.trusted-host mirrors.aliyun.com && npm config set registry https://registry.npmmirror.com && pip install --upgrade pip && pip3 install --user -r requirements.txt && npm install -g @anthropic-ai/claude-code",

  "mounts": [
    // Claude Code（Pro 必须，两个都要挂）
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:HOME}/.claude.json,target=/home/vscode/.claude.json,type=bind",

    // Git 完整配置（alias 等不会自动同步）
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind",

    // SSH Key（用 SSH Agent 转发可省略此项）
    "source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,type=bind,readonly"
  ]
,

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "christian-kohler.path-intellisense",
        "dbaeumer.vscode-eslint",
        "eamodio.gitlens",
        "esbenp.prettier-vscode",
        "github.copilot-chat",
        "ms-azuretools.vscode-containers",
        "ms-python.debugpy",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.vscode-python-envs",
        "oderwat.indent-rainbow"
      ],
      "settings": {
        "python.analysis.typeCheckingMode": "basic",
        "python.analysis.autoImportCompletions": true,
        "python.analysis.inlayHints.variableTypes": true,
        "python.analysis.inlayHints.functionReturnTypes": true,
        "editor.formatOnSave": true,
        "editor.suggestSelection": "first"
      }
    }
  }
}
